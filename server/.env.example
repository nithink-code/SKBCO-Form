# Meta WhatsApp Cloud API credentials
# Get these from developers.facebook.com -> your WhatsApp Business App
WHATSAPP_TOKEN=your_meta_permanent_access_token
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id

# The destination number that should receive every confirmation
# Set this yourself. Format: country code + number, no +, no spaces (e.g. 918861273465)
RECIPIENT_NUMBER=your_number

# Server port
PORT=3000
